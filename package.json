{
    "name": "gooconverter",
    "version": "1.1.1",
    "type": "module",
    "description": "gen string from template",
    "main": "lib/index.cjs",
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "require": "./lib/index.cjs"
        }
    },
    "engines": {
        "node": ">=14.8.0"
    },
    "devDependencies": {
        "acorn": "^8.14.0",
