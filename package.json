{
    "name": "gooplate",
    "version": "1.1.0",
    "type": "module",
    "description": "gen string from template",
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "require": "./lib/index.cjs"
        }
    },
    "engines": {
        "node": ">=14.8.0"
    },
    "devDependencies": {
        "acorn": "^8.17.0",
        "rolldown": "^1.1.1"
    },
    "directories": {
        "lib": "lib"
    },
    "scripts": {
        "build": "rolldown -c && pnpm build:cts && pnpm build:mod",
        "build:cts": "tsc && mv types/index.d.ts lib/index.d.ts && rm -rf types",
        "build:mod": "echo export * from \"./index.js\"; > lib/mod.ts",
        "clean": "rm -rf lib types",
        "dev": "rolldown -c -w",
        "test": "node --test",
        "setup": "pnpm install",
        "prepare": "pnpm build"
    },
    "keywords": [
        "template",
        "string-template",
        "interpolation",
        "placeholder",
        "render",
        "generator",
        "esm"
    ],
    "author": "goosy.jo@gmail.com",
    "license": "MIT",
    "packageManager": "pnpm@11.7.0"
}